@model List<FlashCards.Models.Card>

@{
    ViewData["Title"] = "Все карточки";
}

<h1>Все карточки</h1>

<p>
    <a href="/">На главную</a> |
    <a href="/Card/Add">Добавить карточку</a> |
    <a href="/Card/Stat">Статистика</a> |
    <a href="/Card/Export?n=0&sort=Id">Экспорт JSON</a> |
    <a href="/Card/Test">Тестирование</a>
</p>

<p>
    Сортировка:
    <a href="/Card/All?sort=Id">по Id</a> |
    <a href="/Card/All?sort=Word">по слову</a> |
    <a href="/Card/All?sort=Category">по категории</a>
</p>

<p>
    Ограничение:
    <a href="/Card/All?n=0">все</a> |
    <a href="/Card/All?n=5">5</a> |
    <a href="/Card/All?n=10">10</a>
</p>

<p>
    Текущая сортировка: @ViewData["Sort"] <br />
    Текущее ограничение: @ViewData["N"]
</p>

<table border="1" cellpadding="5">
    <thead>
        <tr>
            <th>Id</th>
            <th>Слово</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var card in Model)
        {
            <tr>
                <td>@card.Id</td>
                <td>@card.Word</td>
                <td>
                    <a href="/Card/Details/@card.Id">Подробнее</a> |
                    <a href="/Card/Edit/@card.Id">Редактировать</a> |
                    <a href="/Card/Remove/@card.Id">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>