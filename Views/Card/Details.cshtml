@model FlashCards.Models.Card

@{
    ViewData["Title"] = "Информация о карточке";
}

<h1>Информация о карточке</h1>

<p>
    <a href="/">На главную</a> |
    <a href="/Card/All">Все карточки</a>
</p>

<table border="1" cellpadding="8">
    <tr>
        <th>Id</th>
        <td>@Model.Id</td>
    </tr>

    <tr>
        <th>Слово</th>
        <td>@Model.Word</td>
    </tr>

    <tr>
        <th>Переводы</th>
        <td>@string.Join(", ", Model.Translations)</td>
    </tr>

    <tr>
        <th>Примеры</th>
        <td>
            @if (Model.Examples.Count == 0)
            {
                <span>Примеры отсутствуют</span>
            }
            else
            {
                <ul>
                    @foreach (var example in Model.Examples)
                    {
                        <li>@example</li>
                    }
                </ul>
            }
        </td>
    </tr>

    <tr>
        <th>Категория</th>
        <td>
            @if (Model.Category != null)
            {
                <table border="1" cellpadding="6">
                    <tr>
                        <th>Id</th>
                        <td>@Model.Category.Id</td>
                    </tr>
                    <tr>
                        <th>Название</th>
                        <td>@Model.Category.Title</td>
                    </tr>
                    <tr>
                        <th>Описание</th>
                        <td>@Model.Category.Description</td>
                    </tr>
                </table>
            }
            else
            {
                <span>Категория не найдена</span>
            }
        </td>
    </tr>
</table>